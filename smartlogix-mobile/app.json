{
  "expo": {
    "name": "smartlogix-mobile",
    "slug": "smartlogix-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/smartlogix-app-icon.png",
    "scheme": "smartlogixmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.smartlogix-mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/smartlogix-app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SmartLogix Driver to use the camera for proof-of-delivery photos."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
